{
    "form_name": "module_layout_detail_form",
    "model": "App\\Models\\ModuleLayout",
    "components": [
        {
            "component": "section",
            "label": "Layout Settings",
            "columnSpan": "full",
            "collapsible": true,
            "compact": true,
            "columns": 2,
            "schema": [
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "module.plural_label",
                    "label": "Module",
                    "columnSpan": 1
                },
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "layout_type",
                    "label": "Layout Type",
                    "dropdown":"layout_type_dom",
                    "columnSpan": 1
                },
                {
                    "component": "textarea",
                    "name": "layout_json",
                    "label": "Layout JSON Configuration",
                    "columnSpan": 2,
                    "rows": 10,
                    "required": true
                }
            ]
        },
        {
            "component": "section",
            "label": "System Info",
            "columnSpan": "full",
            "collapsed": false,
            "compact": true,
            "columns": 4,
            "schema": [
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "created_at",
                    "label": "Created At"
                },
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "updated_at",
                    "label": "Updated At"
                },
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "createdBy.name",
                    "label": "Created By"
                },
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "updatedBy.name",
                    "label": "Updated By"
                }
            ]
        }
    ]
}