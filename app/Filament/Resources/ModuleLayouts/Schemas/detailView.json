{
    "form_name": "module_layout_detail_form",
    "model": "App\\Models\\ModuleLayout",
    "components": [
        {
            "component": "section",
            "label": "Layout Overview",
            "columnSpan": "full",
            "compact": true,
            "columns": 2,
            "schema": [
                {
                    "component": "textEntry",
                    "name": "module.plural_label",
                    "label": "Module",
                    "columnSpan": 1,
                    "size": "lg",
                    "weight": "bold",
                    "color": "primary"
                },
                {
                    "component": "textEntry",
                    "name": "layout_type",
                    "label": "Layout Type",
                    "columnSpan": 1,
                    "badge": true,
                    "color": "info",
                    "size": "md",
                    "dropdown": "layout_type_dom"
                }
            ]
        },
        {
            "component": "section",
            "label": "Layout Structure",
            "columnSpan": "full",
            "compact": false,
            "columns": 1,
            "schema": [
                {
                    "component": "placeholder",
                    "name": "layout_preview",
                    "label": null,
                    "columnSpan": 1,
                    "content_hook": "App\\Helpers\\Studio\\LayoutPreviewHelper@renderLayoutJson"
                }
            ]
        },
        {
            "component": "section",
            "label": "System Info",
            "columnSpan": "full",
            "collapsed": false,
            "compact": true,
            "columns": 4,
            "schema": [
                {
                    "component": "textEntry",
                    "name": "created_at",
                    "label": "Created At",
                    "dateTime": true,
                    "size": "sm",
                    "color": "gray",
                    "inlineLabel": true
                },
                {
                    "component": "textEntry",
                    "name": "updated_at",
                    "label": "Updated At",
                    "dateTime": true,
                    "size": "sm",
                    "color": "gray",
                    "inlineLabel": true
                },
                {
                    "component": "textEntry",
                    "name": "createdBy.name",
                    "label": "Created By",
                    "size": "sm",
                    "weight": "medium",
                    "color": "gray",
                    "inlineLabel": true
                },
                {
                    "component": "textEntry",
                    "name": "updatedBy.name",
                    "label": "Updated By",
                    "size": "sm",
                    "weight": "medium",
                    "color": "gray",
                    "inlineLabel": true
                }
            ]
        }
    ]
}
