{
    "form_name": "module_layout_create_form",
    "model": "App\\Models\\ModuleLayout",
    "components": [
        {
            "component": "section",
            "label": "Layout Settings",
            "columnSpan": "full",
            "collapsible": true,
            "compact": true,
            "columns": 2,
            "schema": [
                {
                    "component": "select",
                    "name": "module_id",
                    "label": "Module",
                    "columnSpan": 1,
                    "options_source": "relationship",
                    "relationship": "module",
                    "title_column": "name",
                    "required": true,
                    "searchable": true,
                    "dehydrated": true,
                    "preload": true,
                    "live": true
                },
                {
                    "component": "select",
                    "name": "layout_type",
                    "label": "Layout Type",
                    "columnSpan": 1,
                    "options_source": "helper",
                    "helper_class": "App\\Helpers\\Studio\\DropdownHandler",
                    "helper_method": "get",
                    "helper_params": [
                        "layout_type_dom"
                    ],
                    "required": true
                },
                {
                    "component": "dragDrop",
                    "name": "layout_json",
                    "label": "Layout Fields (drag to arrange)",
                    "source": "module_fields",
                    "depends_on": "module_id",
                    "columnSpan": 2
                }
            ]
        }
    ]
}