{
    "title": "Module Layouts",
    "model": "App\\Models\\ModuleLayout",
    "perPage": 15,
    "defaultSort": {
        "column": "created_at",
        "direction": "desc"
    },
    "columns": [
        {
            "type": "text",
            "name": "module.plural_label",
            "label": "Module",
            "searchable": {
                "global": true,
                "individual": true
            },
            "sortable": true,
            "wrap": false
        },
        {
            "type": "badge",
            "name": "layout_type",
            "label": "View Type",
            "dropdown": "layout_type_dom",
            "color_map": {
                "create": "success",
                "edit": "warning",
                "detail": "info",
                "list": "primary"
            },
            "sortable": true,
            "searchable": {
                "global": true,
                "individual": false
            }
        },
        {
            "type": "text",
            "name": "layout_json",
            "label": "Sections & Fields",
            "format_hook": "App\\Helpers\\Studio\\LayoutPreviewHelper@formatLayoutSummary",
            "sortable": false
        },
        {
            "type": "text",
            "name": "createdBy.name",
            "label": "Created By",
            "searchable": {
                "global": true,
                "individual": false
            },
            "sortable": false,
            "default": "—"
        },
        {
            "type": "text",
            "name": "created_at",
            "label": "Created",
            "date": true,
            "format": "d M Y, h:i A",
            "sortable": true
        }
    ],
    "filters": [
        {
            "type": "select",
            "name": "layout_type",
            "label": "View Type",
            "options_source": "helper",
            "helper_class": "App\\Helpers\\Studio\\DropdownHandler",
            "helper_method": "get",
            "helper_params": ["layout_type_dom"]
        }
    ],
    "filters_layout": "modal",
    "record_action": null,
    "record_url": null,
    "actions": [
        {
            "type": "view",
            "label": "Details",
            "ui": {
                "hiddenLabel": true,
                "iconButton": true,
                "tooltip": "View Details",
                "icon": "heroicon-o-eye"
            }
        },
        {
            "type": "edit",
            "label": "Edit",
            "ui": {
                "icon": "heroicon-m-pencil-square",
                "slideOver": true,
                "hiddenLabel": true,
                "iconButton": true,
                "tooltip": "Edit Layout",
                "modalHeading": "Update Layout",
                "modalWidth": "SevenExtraLarge"
            }
        },
        {
            "type": "delete",
            "label": "Delete",
            "ui": {
                "hiddenLabel": true,
                "iconButton": true,
                "tooltip": "Delete Layout",
                "icon": "heroicon-o-trash",
                "color": "danger"
            }
        }
    ],
    "record_actions_position": "BeforeColumns",
    "bulkActions": []
}
