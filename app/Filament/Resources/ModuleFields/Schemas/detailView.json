{
    "form_name": "module_field_detail_form",
    "model": "App\\Models\\ModuleField",
    "components": [
        {
            "component": "tabs",
            "columnSpan": "full",
            "tabs": [
                {
                    "label": "General",
                    "schema": [
                        {
                            "component": "grid",
                            "columns": 2,
                            "schema": [
                                {
                                    "component": "textEntry",
                                    "weight": "black",
                                    "name": "module.plural_label",
                                    "label": "Module",
                                    "columnSpan": 1
                                },
                                {
                                    "component": "textEntry",
                                    "weight": "black",
                                    "name": "field_name",
                                    "label": "Field Name",
                                    "columnSpan": 1
                                },
                                {
                                    "component": "textEntry",
                                    "weight": "black",
                                    "name": "label",
                                    "label": "Display Label",
                                    "columnSpan": 1
                                },
                                {
                                    "component": "textEntry",
                                    "weight": "black",
                                    "name": "type",
                                    "dropdown": "field_type_dom",
                                    "label": "Field Type",
                                    "columnSpan": 1
                                },
                                {
                                    "component": "textEntry",
                                    "weight": "black",
                                    "name": "default_value",
                                    "label": "Default Value",
                                    "columnSpan": 2
                                }
                            ]
                        },
                        {
                            "component": "section",
                            "label": "Options (for Select/Radio Components)",
                            "collapsible": true,
                            "compact": true,
                            "columns": 1,
                            "visible_when": {
                                "field": "type",
                                "value": "select"
                            },
                            "schema": [
                                {
                                    "component": "repeater",
                                    "name": "options",
                                    "label": "Options List",
                                    "columnSpan": 1,
                                    "columns": 2,
                                    "schema": [
                                        {
                                            "component": "textEntry",
                                            "weight": "black",
                                            "name": "key",
                                            "label": "Option Value / Key",
                                            "columnSpan": 1
                                        },
                                        {
                                            "component": "textEntry",
                                            "weight": "black",
                                            "name": "value",
                                            "label": "Option Display Label",
                                            "columnSpan": 1
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                },
                {
                    "label": "Validation",
                    "schema": [
                        {
                            "component": "grid",
                            "columns": 2,
                            "schema": [
                                {
                                    "component": "toggle",
                                    "name": "required",
                                    "label": "Required Field",
                                    "columnSpan": 1
                                },
                                {
                                    "component": "toggle",
                                    "name": "unique_field",
                                    "label": "Unique Field",
                                    "columnSpan": 1
                                },
                                {
                                    "component": "textEntry",
                                    "weight": "black",
                                    "name": "length",
                                    "label": "Length (Max Characters)",
                                    "columnSpan": 2
                                }
                            ]
                        }
                    ]
                },
                {
                    "label": "Visibility",
                    "schema": [
                        {
                            "component": "grid",
                            "columns": 2,
                            "schema": [
                                {
                                    "component": "textEntry",
                                    "weight": "black",
                                    "name": "visibility_mode",
                                    "label": "Visibility Mode",
                                    "columnSpan": 1
                                },
                                {
                                    "component": "textEntry",
                                    "weight": "black",
                                    "name": "condition_logic",
                                    "label": "Condition Logic",
                                    "columnSpan": 1,
                                    "visible_when": {
                                        "field": "visibility_mode",
                                        "operator": "!=",
                                        "value": "always_visible"
                                    }
                                },
                                {
                                    "component": "toggle",
                                    "name": "always_save_value",
                                    "label": "Always Save Value",
                                    "columnSpan": 2,
                                    "visible_when": {
                                        "field": "visibility_mode",
                                        "operator": "!=",
                                        "value": "always_visible"
                                    }
                                },
                                {
                                    "component": "repeater",
                                    "name": "visibility_conditions",
                                    "label": "Visibility Conditions",
                                    "columnSpan": 2,
                                    "columns": 3,
                                    "visible_when": {
                                        "field": "visibility_mode",
                                        "operator": "!=",
                                        "value": "always_visible"
                                    },
                                    "schema": [
                                        {
                                            "component": "textEntry",
                                            "weight": "black",
                                            "name": "field",
                                            "label": "Field",
                                            "columnSpan": 1
                                        },
                                        {
                                            "component": "textEntry",
                                            "weight": "black",
                                            "name": "operator",
                                            "label": "Operator",
                                            "columnSpan": 1
                                        },
                                        {
                                            "component": "textEntry",
                                            "weight": "black",
                                            "name": "value",
                                            "label": "Value",
                                            "columnSpan": 1
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "component": "section",
                            "label": "Listing & Search Settings",
                            "collapsible": true,
                            "compact": true,
                            "columns": 3,
                            "schema": [
                                {
                                    "component": "toggle",
                                    "name": "searchable",
                                    "label": "Searchable Field",
                                    "columnSpan": 1
                                },
                                {
                                    "component": "toggle",
                                    "name": "sortable",
                                    "label": "Sortable Field",
                                    "columnSpan": 1
                                },
                                {
                                    "component": "toggle",
                                    "name": "sort_order",
                                    "label": "Sort Order",
                                    "columnSpan": 1
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "component": "section",
            "label": "System Info",
            "columnSpan": "full",
            "collapsed": false,
            "compact": true,
            "columns": 4,
            "schema": [
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "created_at",
                    "label": "Created At"
                },
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "updated_at",
                    "label": "Updated At"
                },
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "createdBy.name",
                    "label": "Created By"
                },
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "updatedBy.name",
                    "label": "Updated By"
                }
            ]
        }
    ]
}