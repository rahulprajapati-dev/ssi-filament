{
    "form_name": "module_field_create_form",
    "model": "App\\Models\\ModuleField",
    "components": [
        {
            "component": "tabs",
            "columnSpan": "full",
            "tabs": [
                {
                    "label": "General",
                    "schema": [
                        {
                            "component": "grid",
                            "columns": 2,
                            "schema": [
                                {
                                    "component": "select",
                                    "name": "module_id",
                                    "label": "Module",
                                    "columnSpan": 1,
                                    "options_source": "relationship",
                                    "relationship": "module",
                                    "title_column": "plural_label",
                                    "required": true,
                                    "searchable": true,
                                    "dehydrated": true,
                                    "preload": true,
                                    "clear_on_update": [
                                        "field"
                                    ]
                                },
                                {
                                    "component": "textInput",
                                    "name": "field_name",
                                    "label": "Field Name",
                                    "columnSpan": 1,
                                    "required": true,
                                    "options_source": "helper",
                                    "helper_type": "dynamic",
                                    "helper_class": "App\\Helpers\\CommonHelper",
                                    "helper_method": "populatefieldlabel",
                                    "helper_params": [
                                        "field_name"
                                    ],
                                    "reactive": true,
                                    "populate_fields": [
                                        "label"
                                    ],
                                    "validation": [
                                        "max:50",
                                        "regex:/^[a-z][a-z0-9_]*$/"
                                    ]
                                },
                                {
                                    "component": "textInput",
                                    "name": "label",
                                    "label": "Display Label",
                                    "columnSpan": 1,
                                    "required": true
                                },
                                {
                                    "component": "select",
                                    "name": "type",
                                    "label": "Field Type",
                                    "columnSpan": 1,
                                    "options_source": "helper",
                                    "helper_class": "App\\Helpers\\Studio\\DropdownHandler",
                                    "helper_method": "get",
                                    "helper_params": [
                                        "field_type_dom"
                                    ],
                                    "searchable": true,
                                    "reactive": true,
                                    "required": true
                                },
                                {
                                    "component": "textInput",
                                    "name": "default_value",
                                    "label": "Default Value",
                                    "columnSpan": 2,
                                    "required": false
                                }
                            ]
                        },
                        {
                            "component": "section",
                            "label": "Options (for Select / Radio / Checkbox List)",
                            "collapsible": true,
                            "compact": true,
                            "columns": 1,
                            "visible_when": {
                                "field": "type",
                                "operator": "in",
                                "value": ["select", "radio", "checkbox_list"]
                            },
                            "schema": [
                                {
                                    "component": "repeater",
                                    "name": "options",
                                    "label": "Options List",
                                    "columnSpan": 1,
                                    "columns": 2,
                                    "schema": [
                                        {
                                            "component": "textInput",
                                            "name": "key",
                                            "label": "Option Value / Key",
                                            "columnSpan": 1,
                                            "required": true
                                        },
                                        {
                                            "component": "textInput",
                                            "name": "value",
                                            "label": "Option Display Label",
                                            "columnSpan": 1,
                                            "required": true
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                },
                {
                    "label": "Validation",
                    "schema": [
                        {
                            "component": "grid",
                            "columns": 2,
                            "schema": [
                                {
                                    "component": "toggle",
                                    "name": "required",
                                    "label": "Required Field",
                                    "columnSpan": 1
                                },
                                {
                                    "component": "toggle",
                                    "name": "unique_field",
                                    "label": "Unique Field",
                                    "columnSpan": 1
                                },
                                {
                                    "component": "textInput",
                                    "name": "length",
                                    "label": "Length (Max Characters)",
                                    "type": "numeric",
                                    "columnSpan": 2,
                                    "required": false
                                }
                            ]
                        }
                    ]
                },
                {
                    "label": "Visibility",
                    "schema": [
                        {
                            "component": "grid",
                            "columns": 2,
                            "schema": [
                                {
                                    "component": "select",
                                    "name": "visibility_mode",
                                    "label": "Visibility Mode",
                                    "columnSpan": 1,
                                    "options_source": "helper",
                                    "helper_class": "App\\Helpers\\Studio\\DropdownHandler",
                                    "helper_method": "get",
                                    "helper_params": [
                                        "visibility_mode_dom"
                                    ],
                                    "required": true,
                                    "reactive": true,
                                    "default": "always_visible"
                                },
                                {
                                    "component": "select",
                                    "name": "condition_logic",
                                    "label": "Condition Logic",
                                    "columnSpan": 1,
                                    "options_source": "helper",
                                    "helper_class": "App\\Helpers\\Studio\\DropdownHandler",
                                    "helper_method": "get",
                                    "helper_params": [
                                        "condition_logic_dom"
                                    ],
                                    "required": true,
                                    "default": "and",
                                    "visible_when": {
                                        "field": "visibility_mode",
                                        "operator": "!=",
                                        "value": "always_visible"
                                    }
                                },
                                {
                                    "component": "toggle",
                                    "name": "always_save_value",
                                    "label": "Always Save Value (Save field value even when hidden)",
                                    "columnSpan": 2,
                                    "visible_when": {
                                        "field": "visibility_mode",
                                        "operator": "!=",
                                        "value": "always_visible"
                                    }
                                },
                                {
                                    "component": "repeater",
                                    "name": "visibility_conditions",
                                    "label": "Visibility Conditions",
                                    "columnSpan": 2,
                                    "columns": 3,
                                    "visible_when": {
                                        "field": "visibility_mode",
                                        "operator": "!=",
                                        "value": "always_visible"
                                    },
                                    "schema": [
                                        {
                                            "component": "select",
                                            "name": "field",
                                            "label": "Field",
                                            "columnSpan": 1,
                                            "helper_type": "dynamic",
                                            "options_source": "helper",
                                            "helper_class": "App\\Helpers\\CommonHelper",
                                            "helper_method": "getModuleFieldsOptions",
                                            "helper_params": [
                                                "../../module_id"
                                            ],
                                            "required": true
                                        },
                                        {
                                            "component": "select",
                                            "name": "operator",
                                            "label": "Operator",
                                            "columnSpan": 1,
                                            "options_source": "helper",
                                            "helper_class": "App\\Helpers\\Studio\\DropdownHandler",
                                            "helper_method": "get",
                                            "helper_params": [
                                                "operator_dom"
                                            ],
                                            "searchable": true,
                                            "reactive": true,
                                            "required": true
                                        },
                                        {
                                            "component": "textInput",
                                            "name": "value",
                                            "label": "Value",
                                            "columnSpan": 1,
                                            "required": true
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "component": "section",
                            "label": "Listing & Search Settings",
                            "collapsible": true,
                            "compact": true,
                            "columns": 3,
                            "schema": [
                                {
                                    "component": "toggle",
                                    "name": "searchable",
                                    "label": "Searchable Field",
                                    "columnSpan": 1
                                },
                                {
                                    "component": "toggle",
                                    "name": "sortable",
                                    "label": "Sortable Field",
                                    "columnSpan": 1
                                },
                                {
                                    "component": "toggle",
                                    "name": "sort_order",
                                    "label": "Sort Order",
                                    "columnSpan": 1
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}