{
    "form_name": "module_field_create_form",
    "model": "App\\Models\\ModuleField",
    "components": [
        {
            "component": "section",
            "label": "Field Configuration",
            "columnSpan": "full",
            "collapsible": true,
            "compact": true,
            "columns": 6,
            "schema": [
                {
                    "component": "select",
                    "name": "module_id",
                    "label": "Module",
                    "columnSpan": 1,
                    "options_source": "relationship",
                    "relationship": "module",
                    "title_column": "name",
                    "required": true,
                    "searchable": true,
                    "dehydrated": true,
                    "preload": true
                },
                {
                    "component": "textInput",
                    "name": "field_name",
                    "label": "Field Name",
                    "columnSpan": 1,
                    "required": true,
                    "options_source": "helper",
                    "helper_type": "dynamic",
                    "helper_class": "App\\Helpers\\CommonHelper",
                    "helper_method": "populatefieldlabel",
                    "helper_params": [
                        "field_name"
                    ],
                    "reactive": true,
                    "populate_fields": [
                       "label"
                    ],
                    "validation":[
                        "max:50",
                        "regex:/^[a-z][a-z0-9_]*$/"
                    ]
                },
                {
                    "component": "textInput",
                    "name": "label",
                    "label": "Display Label",
                    "columnSpan": 1,
                    "required": true
                },
                {
                    "component": "select",
                    "name": "type",
                    "label": "Field Type",
                    "columnSpan": 1,
                    "options_source": "helper",
                    "helper_class": "App\\Helpers\\Studio\\DropdownHandler",
                    "helper_method": "get",
                    "helper_params": [
                        "field_type_dom"
                    ],
                    "searchable":true,
                    "reactive": true,
                    "required": true
                },
                {
                    "component": "textInput",
                    "name": "length",
                    "label": "Length (Max Characters)",
                    "type": "numeric",
                    "columnSpan": 1,
                    "required": false
                },
                {
                    "component": "textInput",
                    "name": "default_value",
                    "label": "Default Value",
                    "columnSpan": 1,
                    "required": false
                },
                {
                    "component": "toggle",
                    "name": "sort_order",
                    "label": "Sort Order",
                    "columnSpan": 1
                },
                {
                    "component": "toggle",
                    "name": "required",
                    "label": "Required Field",
                    "columnSpan": 1
                },
                {
                    "component": "toggle",
                    "name": "searchable",
                    "label": "Searchable Field",
                    "columnSpan": 1
                },
                {
                    "component": "toggle",
                    "name": "sortable",
                    "label": "Sortable Field",
                    "columnSpan": 1
                },
                {
                    "component": "toggle",
                    "name": "unique_field",
                    "label": "Unique Field",
                    "columnSpan": 1
                }
            ]
        },
        {
            "component": "section",
            "label": "Options (for Select/Radio Components)",
            "columnSpan": "full",
            "collapsible": true,
            "compact": true,
            "columns": 1,
            "visible_when":{
                "field":"type",
                "value":"select"
            },
            "schema": [
                {
                    "component": "repeater",
                    "name": "options",
                    "label": "Options List",
                    "columnSpan": 1,
                    "columns": 2,
                    "schema": [
                        {
                            "component": "textInput",
                            "name": "key",
                            "label": "Option Value / Key",
                            "columnSpan": 1,
                            "required": true
                        },
                        {
                            "component": "textInput",
                            "name": "value",
                            "label": "Option Display Label",
                            "columnSpan": 1,
                            "required": true
                        }
                    ]
                }
            ]
        }
    ]
}