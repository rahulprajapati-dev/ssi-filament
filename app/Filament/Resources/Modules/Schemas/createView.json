{
    "form_name": "module_create_form",
    "model": "App\\Models\\Module",
    "components": [
        {
            "component": "section",
            "label": "Module Identity",
            "description": "Define the module name and display labels. The name is used as the database table key — lowercase letters, numbers, and underscores only.",
            "icon": "heroicon-o-cube",
            "columnSpan": "full",
            "collapsible": false,
            "compact": true,
            "columns": 2,
            "schema": [
                {
                    "component": "textInput",
                    "name": "name",
                    "label": "Module Name",
                    "columnSpan": 1,
                    "options_source": "helper",
                    "helper_type": "dynamic",
                    "helper_class": "App\\Helpers\\CommonHelper",
                    "helper_method": "populatemodulelabes",
                    "populate_mode": "create",
                    "unique": true,
                    "helper_params": [
                        "name"
                    ],
                    "reactive": true,
                    "required": true,
                    "populate_fields": [
                        "singular_label",
                        "plural_label"
                    ],
                    "hint": "Lowercase, underscores only — e.g. customer_order",
                    "validation": [
                        "max:50",
                        "regex:/^[a-z][a-z0-9_]*$/"
                    ]
                },
                {
                    "component": "select",
                    "name": "icon",
                    "label": "Navigation Icon",
                    "options_source": "helper",
                    "helper_class": "App\\Helpers\\Studio\\DropdownHandler",
                    "helper_method": "get",
                    "helper_params": [
                        "moudle_icons_dom"
                    ],
                    "columnSpan": 1,
                    "required": false,
                    "hint": "Heroicon displayed in the sidebar navigation"
                },
                {
                    "component": "textInput",
                    "name": "singular_label",
                    "label": "Singular Label",
                    "columnSpan": 1,
                    "required": true,
                    "hint": "e.g. Customer Order"
                },
                {
                    "component": "textInput",
                    "name": "plural_label",
                    "label": "Plural Label",
                    "columnSpan": 1,
                    "required": true,
                    "hint": "e.g. Customer Orders"
                },
                {
                    "component": "textarea",
                    "name": "description",
                    "label": "Description",
                    "columnSpan": 2,
                    "rows": 3,
                    "required": false,
                    "hint": "Optional — briefly describe what this module manages"
                }
            ]
        }
    ]
}
