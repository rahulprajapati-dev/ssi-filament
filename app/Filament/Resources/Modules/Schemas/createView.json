{
    "form_name": "module_create_form",
    "model": "App\\Models\\Module",
    "components": [
        {
            "component": "section",
            "label": "Module Information",
            "columnSpan": "full",
            "collapsible": true,
            "compact": true,
            "columns": 2,
            "schema": [
                {
                    "component": "textInput",
                    "name": "name",
                    "label": "Name",
                    "columnSpan": 1,
                    "options_source": "helper",
                    "helper_type": "dynamic",
                    "helper_class": "App\\Helpers\\CommonHelper",
                    "helper_method": "populatemodulelabes",
                    "populate_mode": "create",
                    "unique": true,
                    "helper_params": [
                        "name"
                    ],
                    "reactive": true,
                    "required": true,
                    "populate_fields": [
                       "singular_label",
                       "plural_label"
                    ],
                    "validation":[
                        "max:50",
                        "regex:/^[a-z][a-z0-9_]*$/"
                    ]
                    
                },
                {
                    "component": "select",
                    "name": "icon",
                    "label": "Icon (Heroicon)",
                    "options_source": "helper",
                    "helper_class": "App\\Helpers\\Studio\\DropdownHandler",
                    "helper_method": "get",
                    "helper_params": [
                        "moudle_icons_dom"
                    ],
                    "columnSpan": 1,
                    "required": false
                },
                {
                    "component": "textInput",
                    "name": "singular_label",
                    "label": "Singular Label",
                    "columnSpan": 1,
                    "required": true
                },
                {
                    "component": "textInput",
                    "name": "plural_label",
                    "label": "Plural Label",
                    "columnSpan": 1,
                    "required": true
                },
                {
                    "component": "textarea",
                    "name": "description",
                    "label": "Description",
                    "columnSpan": 2,
                    "rows": 3,
                    "required": false
                }
            ]
        }
    ]
}