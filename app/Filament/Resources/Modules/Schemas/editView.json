{
    "form_name": "module_edit_form",
    "model": "App\\Models\\Module",
    "components": [
        {
            "component": "section",
            "label": "Module Identity",
            "description": "Update display labels and navigation icon. The module name cannot be changed once the module is deployed.",
            "icon": "heroicon-o-cube",
            "columnSpan": "full",
            "collapsible": false,
            "compact": true,
            "columns": 2,
            "schema": [
                {
                    "component": "textInput",
                    "name": "name",
                    "label": "Module Name",
                    "columnSpan": 1,
                    "options_source": "helper",
                    "helper_type": "dynamic",
                    "helper_class": "App\\Helpers\\CommonHelper",
                    "helper_method": "populatemodulelabes",
                    "unique": true,
                    "helper_params": [
                        "name"
                    ],
                    "reactive": true,
                    "required": true,
                    "populate_fields": [
                        "singular_label",
                        "plural_label"
                    ],
                    "hint": "Locked after deployment — rename requires re-deploy",
                    "disabled_when": {
                        "field": "is_deploy",
                        "value": true
                    },
                    "validation": [
                        "max:50",
                        "regex:/^[a-z][a-z0-9_]*$/"
                    ]
                },
                {
                    "component": "select",
                    "name": "icon",
                    "label": "Navigation Icon",
                    "options_source": "helper",
                    "helper_class": "App\\Helpers\\Studio\\DropdownHandler",
                    "helper_method": "get",
                    "helper_params": [
                        "moudle_icons_dom"
                    ],
                    "columnSpan": 1,
                    "required": false,
                    "hint": "Heroicon displayed in the sidebar navigation"
                },
                {
                    "component": "textInput",
                    "name": "singular_label",
                    "label": "Singular Label",
                    "columnSpan": 1,
                    "required": true,
                    "hint": "e.g. Customer Order"
                },
                {
                    "component": "textInput",
                    "name": "plural_label",
                    "label": "Plural Label",
                    "columnSpan": 1,
                    "required": true,
                    "hint": "e.g. Customer Orders"
                },
                {
                    "component": "textarea",
                    "name": "description",
                    "label": "Description",
                    "columnSpan": 2,
                    "rows": 3,
                    "required": false,
                    "hint": "Optional — briefly describe what this module manages"
                }
            ]
        },
        {
            "component": "section",
            "label": "Module Relationships",
            "description": "Define Eloquent relationships this module has with other modules. These are used when generating model code.",
            "icon": "heroicon-o-arrow-path-rounded-square",
            "columnSpan": "full",
            "collapsible": true,
            "compact": false,
            "columns": 1,
            "schema": [
                {
                    "component": "repeater",
                    "name": "relationships_json",
                    "label": null,
                    "columnSpan": 1,
                    "columns": 4,
                    "schema": [
                        {
                            "component": "select",
                            "name": "type",
                            "label": "Relationship Type",
                            "columnSpan": 1,
                            "options_source": "helper",
                            "helper_class": "App\\Helpers\\Studio\\DropdownHandler",
                            "helper_method": "get",
                            "helper_params": [
                                "relationship_type_dom"
                            ],
                            "required": true,
                            "searchable": false
                        },
                        {
                            "component": "select",
                            "name": "related_module",
                            "label": "Related Module",
                            "columnSpan": 1,
                            "options_source": "helper",
                            "helper_class": "App\\Helpers\\CommonHelper",
                            "helper_method": "getModulesOptions",
                            "helper_params": [],
                            "required": true,
                            "searchable": true
                        },
                        {
                            "component": "textInput",
                            "name": "name",
                            "label": "Method Name",
                            "columnSpan": 1,
                            "required": false,
                            "hint": "e.g. orders — auto-suggested if left empty"
                        },
                        {
                            "component": "textInput",
                            "name": "foreign_key",
                            "label": "Foreign Key",
                            "columnSpan": 1,
                            "required": false,
                            "hint": "Leave empty for convention (e.g. module_id)"
                        }
                    ]
                }
            ]
        }
    ]
}
