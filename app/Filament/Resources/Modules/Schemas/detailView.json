{
    "form_name": "module_detail_form",
    "model": "App\\Models\\Module",
    "components": [
        {
            "component": "section",
            "label": "Module Identity",
            "icon": "heroicon-o-cube",
            "columnSpan": "full",
            "compact": true,
            "columns": 3,
            "schema": [
                {
                    "component": "textEntry",
                    "name": "name",
                    "label": "Module Name",
                    "columnSpan": 1,
                    "size": "lg",
                    "weight": "bold",
                    "color": "primary",
                    "copyable": true
                },
                {
                    "component": "textEntry",
                    "name": "singular_label",
                    "label": "Singular Label",
                    "columnSpan": 1,
                    "size": "md",
                    "weight": "semibold"
                },
                {
                    "component": "textEntry",
                    "name": "plural_label",
                    "label": "Plural Label",
                    "columnSpan": 1,
                    "size": "md",
                    "weight": "semibold"
                },
                {
                    "component": "textEntry",
                    "name": "icon",
                    "label": "Navigation Icon",
                    "columnSpan": 1,
                    "badge": true,
                    "color": "gray",
                    "size": "sm"
                },
                {
                    "component": "textEntry",
                    "name": "description",
                    "label": "Description",
                    "columnSpan": 2,
                    "size": "sm",
                    "color": "gray"
                }
            ]
        },
        {
            "component": "section",
            "label": "Deployment Status",
            "icon": "heroicon-o-cloud-arrow-up",
            "columnSpan": "full",
            "compact": true,
            "columns": 3,
            "schema": [
                {
                    "component": "toggle",
                    "name": "is_deploy",
                    "label": "Deployed",
                    "columnSpan": 1
                },
                {
                    "component": "toggle",
                    "name": "is_enable",
                    "label": "Enabled",
                    "columnSpan": 1
                },
                {
                    "component": "textEntry",
                    "name": "deployed_at",
                    "label": "Deployed At",
                    "columnSpan": 1,
                    "dateTime": true,
                    "size": "sm",
                    "weight": "semibold",
                    "color": "success"
                }
            ]
        },
        {
            "component": "section",
            "label": "System Info",
            "columnSpan": "full",
            "collapsed": false,
            "compact": true,
            "columns": 4,
            "schema": [
                {
                    "component": "textEntry",
                    "name": "created_at",
                    "label": "Created At",
                    "dateTime": true,
                    "size": "sm",
                    "color": "gray",
                    "inlineLabel": true
                },
                {
                    "component": "textEntry",
                    "name": "updated_at",
                    "label": "Updated At",
                    "dateTime": true,
                    "size": "sm",
                    "color": "gray",
                    "inlineLabel": true
                },
                {
                    "component": "textEntry",
                    "name": "createdBy.name",
                    "label": "Created By",
                    "size": "sm",
                    "weight": "medium",
                    "color": "gray",
                    "inlineLabel": true
                },
                {
                    "component": "textEntry",
                    "name": "updatedBy.name",
                    "label": "Updated By",
                    "size": "sm",
                    "weight": "medium",
                    "color": "gray",
                    "inlineLabel": true
                }
            ]
        }
    ]
}
