{
    "form_name": "module_detail_form",
    "model": "App\\Models\\Module",
    "components": [
        {
            "component": "section",
            "label": "Module Information",
            "columnSpan": "full",
            "collapsible": true,
            "compact": true,
            "columns": 2,
            "schema": [
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "name",
                    "label": "Name",
                    "columnSpan": 1
                },
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "icon",
                    "label": "Icon (Heroicon)",
                    "columnSpan": 1
                },
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "singular_label",
                    "label": "Singular Label",
                    "columnSpan": 1
                },
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "plural_label",
                    "label": "Plural Label",
