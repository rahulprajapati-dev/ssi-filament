            "compact": true,
            "columns": 4,
            "schema": [
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "created_at",
                    "label": "Created At"
                },
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "updated_at",
                    "label": "Updated At"
                },
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "createdBy.name",
                    "label": "Created By"
                },
                {
                    "component": "textEntry",
                    "weight": "black",
                    "name": "updatedBy.name",
                    "label": "Updated By"
                }
            ]
