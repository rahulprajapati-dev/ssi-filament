{
    "title": "Modules",
    "model": "App\\Models\\Module",
    "perPage": 10,
    "defaultSort": {
        "column": "created_at",
        "direction": "desc"
    },
    "columns": [
        {
            "type": "text",
            "name": "name",
            "label": "Name",
            "searchable": {
                "global": true,
                "individual": true
            },
            "sortable": true
        },
        {
            "type": "text",
            "name": "singular_label",
            "label": "Singular Label",
            "searchable": {
                "global": true,
                "individual": true
            },
            "sortable": true
        },
        {
            "type": "text",
            "name": "plural_label",
            "label": "Plural Label",
            "searchable": {
                "global": true,
                "individual": true
            },
            "sortable": true
        },
        {
            "type": "text",
            "name": "icon",
            "label": "Icon",
            "searchable": {
                "global": true,
                "individual": true
            },
            "sortable": true
        },
        {
            "type": "text",
            "name": "description",
            "label": "Description",
            "searchable": {
                "global": true,
                "individual": true
            },
            "sortable": true
        },
        {
            "type": "text",
            "name": "created_by",
            "label": "Created By",
            "sortable": true
        },
        {
            "type": "text",
            "name": "created_at",
            "label": "Created At",
            "date": true,
            "sortable": true
        }
    ],
    "filters": [],
    "filters_layout": "modal",
    "record_action": null,
    "record_url": null,
    "actions": [
        {
            "type": "edit",
            "label": "Edit",
            "ui": {
                "icon": "heroicon-m-pencil-square",
                "slideOver": true,
                "hiddenLabel": true,
                "iconButton": true,
                "tooltip": "Edit",
                "modalHeading": "Update the module",
                "modalWidth": "SevenExtraLarge"
            }
        },
        {
            "type": "view",
            "label": "Details",
            "ui": {
                "hiddenLabel": true,
                "iconButton": true,
                "tooltip": "Details",
                "icon": "heroicon-o-eye"
            }
        },
        {
            "type": "group",
            "label": "More",
            "icon": "heroicon-o-ellipsis-horizontal",
            "items": [
                {
                    "type": "custom",
                    "name": "toggle_module",
                    "label": "Enable / Disable",
                    "ui": {
                        "icon": "heroicon-o-power",
                        "color": "warning",
                        "modalHeading": "Change Module Status",
                        "modalDescription": "Are you sure you want to change the status of this module?",
                        "modalSubmitActionLabel": "Confirm",
                        "modalWidth": "Medium"
                    },
                    "hooks": {
                        "action": "\\App\\Filament\\Resources\\Modules\\Hooks\\ModuleHooks@toggleModule"
                    }
                },
                {
                    "type": "custom",
                    "name": "deploy_module",
                    "label": "Deploy Module",
                    "ui": {
                        "icon": "heroicon-o-cloud-arrow-up",
                        "color": "warning",
                        "modalHeading": "Deploy Module",
                        "modalDescription": "Are you sure you want to deploy this module?",
                        "modalSubmitActionLabel": "Yes, Deploy",
                        "modalWidth": "Medium"
                    },
                    "hooks": {
                        "action": "\\App\\Filament\\Resources\\Modules\\Hooks\\ModuleHooks@deployModule"
                    }
                }
            ]
        }
    ],
    "record_actions_position": "BeforeColumns",
    "bulkActions": []
}