{
    "title": "Modules",
    "model": "App\\Models\\Module",
    "perPage": 15,
    "defaultSort": {
        "column": "created_at",
        "direction": "desc"
    },
    "columns": [
        {
            "type": "text",
            "name": "plural_label",
            "label": "Module Name",
            "searchable": {
                "global": true,
                "individual": true
            },
            "sortable": true,
            "wrap": false
        },
        {
            "type": "text",
            "name": "singular_label",
            "label": "Label",
            "searchable": {
                "global": true,
                "individual": false
            },
            "sortable": true
        },
        {
            "type": "icon",
            "name": "is_deploy",
            "label": "Deployed",
            "boolean": true,
            "sortable": true
        },
        {
            "type": "icon",
            "name": "is_enable",
            "label": "Enabled",
            "boolean": true,
            "sortable": true
        },
        {
            "type": "text",
            "name": "deployed_at",
            "label": "Deployed At",
            "date": true,
            "format": "d M Y",
            "sortable": true,
            "default": "—"
        },
        {
            "type": "text",
            "name": "created_at",
            "label": "Created",
            "date": true,
            "format": "d M Y",
            "sortable": true
        }
    ],
    "filters": [],
    "filters_layout": "modal",
    "record_action": null,
    "record_url": null,
    "actions": [
        {
            "type": "view",
            "label": "Details",
            "ui": {
                "hiddenLabel": true,
                "iconButton": true,
                "tooltip": "View Details",
                "icon": "heroicon-o-eye"
            }
        },
        {
            "type": "edit",
            "label": "Edit",
            "ui": {
                "icon": "heroicon-m-pencil-square",
                "slideOver": true,
                "hiddenLabel": true,
                "iconButton": true,
                "tooltip": "Edit Module",
                "modalHeading": "Update Module",
                "modalWidth": "SevenExtraLarge"
            }
        },
        {
            "type": "group",
            "label": "More",
            "icon": "heroicon-o-ellipsis-horizontal",
            "items": [
                {
                    "type": "custom",
                    "name": "toggle_module",
                    "label": "Enable / Disable",
                    "hidden_when": {
                        "field": "is_deploy",
                        "value": false
                    },
                    "ui": {
                        "icon": "heroicon-o-power",
                        "color": "warning",
                        "modalHeading": "Change Module Status",
                        "modalDescription": "Are you sure you want to change the status of this module?",
                        "modalSubmitActionLabel": "Confirm",
                        "modalWidth": "Medium"
                    },
                    "hooks": {
                        "action": "\\App\\Filament\\Resources\\Modules\\Hooks\\ModuleHooks@toggleModule"
                    }
                },
                {
                    "type": "custom",
                    "name": "deploy_module",
                    "label": "Deploy",
                    "hidden_when": {
                        "field": "is_deploy",
                        "value": true
                    },
                    "ui": {
                        "icon": "heroicon-o-cloud-arrow-up",
                        "color": "success",
                        "modalHeading": "Deploy Module",
                        "modalDescription": "This will generate all required files, database migrations, models, resources, and layouts for this module. Do you want to continue?",
                        "modalSubmitActionLabel": "Yes, Deploy",
                        "modalWidth": "Medium"
                    },
                    "hooks": {
                        "action": "\\App\\Filament\\Resources\\Modules\\Hooks\\ModuleHooks@deployModule"
                    }
                },
                {
                    "type": "custom",
                    "name": "uninstall",
                    "label": "Uninstall",
                    "hidden_when": {
                        "field": "is_deploy",
                        "value": false
                    },
                    "ui": {
                        "icon": "heroicon-o-trash",
                        "color": "danger",
                        "modalHeading": "Uninstall Module",
                        "modalDescription": "This action will remove all generated files, resources, and configurations for this module. You can optionally remove the database table as well. This action cannot be undone.",
                        "modalSubmitActionLabel": "Yes, Uninstall",
                        "modalWidth": "Medium"
                    },
                    "form": {
                        "components": [
                            {
                                "component": "grid",
                                "schema": [
                                    {
                                        "component": "toggle",
                                        "name": "is_table",
                                        "label": "Also drop the database table?"
                                    }
                                ]
                            }
                        ]
                    },
                    "hooks": {
                        "action": "\\App\\Filament\\Resources\\Modules\\Hooks\\ModuleHooks@uninstall"
                    }
                },
                {
                    "type": "custom",
                    "name": "repair_rebuild",
                    "label": "Repair & Rebuild",
                    "hidden_when": {
                        "field": "is_deploy",
                        "value": false
                    },
                    "ui": {
                        "icon": "heroicon-o-arrow-path",
                        "color": "warning",
                        "modalHeading": "Repair & Rebuild Module",
                        "modalDescription": "This will repair and rebuild the module by regenerating missing files and ensuring the database schema and layouts are up to date. Do you want to continue?",
                        "modalSubmitActionLabel": "Yes, Repair & Rebuild",
                        "modalWidth": "Medium"
                    },
                    "hooks": {
                        "action": "\\App\\Filament\\Resources\\Modules\\Hooks\\ModuleHooks@repairRebuild"
                    }
                },
                {
                    "type": "delete",
                    "name": "delete",
                    "label": "Delete",
                    "hidden_when": {
                        "field": "is_deploy",
                        "value": true
                    }
                }
            ]
        }
    ],
    "record_actions_position": "BeforeColumns",
    "bulkActions": []
}
